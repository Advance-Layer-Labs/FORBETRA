# Forbetra — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env — it's in .gitignore.

# ── Database (Neon PostgreSQL) ──────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ── Clerk Auth ──────────────────────────────────────────────
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ── Email: SendGrid (primary) ──────────────────────────────
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=sagal@thewinningmind.com

# ── Email: Postmark (fallback — optional) ──────────────────
POSTMARK_API_KEY=
POSTMARK_FROM_EMAIL=noreply@thewinningmind.com

# Set to "mock" to log emails to console instead of sending.
# Defaults to "mock" in development, "send" in production.
EMAIL_MODE=mock

# ── SMS: Twilio ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_MESSAGING_SERVICE_SID=MG...

# Set to "mock" to log SMS to console instead of sending.
# Defaults to "mock" in development, "send" in production.
SMS_MODE=mock

# ── AI: Anthropic ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
# Optional model override. Defaults to claude-sonnet-4-5-20250929.
# To upgrade to a newer Sonnet/Opus, set here and restart — no code change needed.
# Test prompt output before promoting, model behavior can shift between versions.
ANTHROPIC_MODEL_ID=

# ── Cron / Jobs ─────────────────────────────────────────────
# Used to authenticate Vercel cron job requests.
# CRON_SECRET on Vercel must match this value.
JOB_SECRET_TOKEN=

# ── Rate Limiting: Upstash Redis ───────────────────────────
# Required in production. Without these, rateLimit.ts falls back to an
# in-memory store that resets on every Vercel cold start — effectively no
# rate limiting at all on serverless. Provision a Redis instance at
# upstash.com and paste the REST URL + token here.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Error Monitoring: Sentry ───────────────────────────────
# Client DSN (safe to expose in browser). Leave blank to disable.
VITE_SENTRY_DSN=
# Server DSN (private). Leave blank to disable.
SENTRY_DSN=

# ── Debug (optional) ───────────────────────────────────────
# Enables /api/debug/email and /api/debug/sms endpoints.
DEBUG_EMAIL_KEY=
